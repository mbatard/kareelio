# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=kareelio
POSTGRES_USER=kareelio
POSTGRES_PASSWORD=changeme

# Backend
SERVER_PORT=8080
SESSION_SECRET=changeme-use-secure-random-string
SESSION_COOKIE_SAMESITE=lax
SESSION_DURATION_HOURS=72
DEFAULT_ADMIN_EMAIL=admin@kareelio.local
DEFAULT_ADMIN_PASSWORD=admin
CORS_ORIGIN=http://localhost:5173
DB_MIGRATE=true

# Registration & Email Verification
APP_PUBLIC_URL=http://localhost:5173
REGISTRATION_ENABLED=true
VERIFICATION_TOKEN_TTL_HOURS=24

# SMTP (leave empty to log verification links to stdout)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@kareelio.fr

# Frontend
VITE_API_URL=http://localhost:8080
